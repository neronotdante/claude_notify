{
  "name": "claude-notify",
  "version": "1.0.0",
  "description": "Windows Toast 通知 Hook：对话含 [notify] / -notify / !done 等关键字时弹出系统通知，标题自动显示当前项目名。",
  "owner": {
    "name": "local"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"e:/HF.Work/98claudeCodeLearning/claude_notify/.claude-plugin/notify/src/notify.py\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}